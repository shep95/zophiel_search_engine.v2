{
  "name": "zophiel-search-engine-v2",
  "version": "0.1.0",
  "description": "Zophiel Search Engine v2 — Ghost Chain Protocol intelligent crawler and custom search engine",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-bundle.js",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "worker": "tsx src/worker.ts",
    "api": "tsx src/api/server.ts",
    "crawl": "tsx src/cli.ts crawl",
    "search": "tsx src/cli.ts search",
    "investigate": "tsx src/cli.ts investigate",
    "playwright:install": "playwright install chromium"
  },
  "keywords": ["crawler", "search-engine", "playwright", "typescript"],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "better-sqlite3": "^11.8.1",
    "cheerio": "^1.0.0",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.50.1",
    "robots-parser": "^3.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
